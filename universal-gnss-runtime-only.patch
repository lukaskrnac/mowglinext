+  -p "input_rtcm_topic:=${internal_rtcm_topic}" \
+  -p "output_rtcm_topic:=/rtcm" &
+UNIVERSAL_BRIDGE_PID=$!
+
+if [ "$ntrip_enabled" = "true" ]; then
+  echo "[start_gps.sh] Runtime=universal NTRIP enabled: ${ntrip_host}:${ntrip_port}/${ntrip_mountpoint}"
+  sleep 3
